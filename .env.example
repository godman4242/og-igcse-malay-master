# Environment Configuration
# Copy this file to .env.local and fill in your values

# Phase 1: Supabase Backend
# 1. Sign up at https://supabase.com
# 2. Create new project
# 3. Go to Settings > API to find these values
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_KEY=your-anon-key-here

# Translation API (optional)
# Google Translate API key for fallback translation
# Leave empty to disable API-based translation (dict + stemming still works)
VITE_TRANSLATE_API_KEY=your-google-api-key-here

# Claude API for LLM essay feedback (Phase 1)
# https://console.anthropic.com
VITE_CLAUDE_API_KEY=sk-ant-your-key-here

# Analytics (Phase 2)
# Posthog or Plausible
VITE_POSTHOG_KEY=your-posthog-key
VITE_PLAUSIBLE_DOMAIN=yourdomain.com

# Deployment
# Vercel secrets (set in Vercel dashboard, not here)
# VERCEL_TOKEN
# VERCEL_ORG_ID
# VERCEL_PROJECT_ID

# AI Features (Phase 2)
# Set to "true" to use canned mock responses instead of calling Claude API
# Useful for development and testing without API costs
VITE_AI_MOCK=true

# App Environment
VITE_APP_ENV=development
# Options: development, staging, production
